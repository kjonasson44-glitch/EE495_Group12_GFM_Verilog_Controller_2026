module srf_pll_1 (
    input wire clk,                  // 25 MHz system clock
    input wire reset,                // Active low reset
    input wire clk_en,              // 720 Hz sampling strobe (enable signal)
    input wire signed [17:0] q_in,  // q-axis voltage (Error signal from dq transform) 
    
    output reg signed [31:0] freq_out // Output frequency word for NCO
);

    // =========================================================================
    // PARAMETERS & CONSTANTS
    // =========================================================================
    
    // Center Frequency: 59 Hz at 720 Hz sampling rate 
    // Calculation verified: (32'sd357913941 / 2^32) * 720 Hz ~= 60.0 Hz
    localparam signed [31:0] CENTER_FREQ = 32'sd357913941; // [cite: 184, 199]

    // PI Controller Gains
    // Note: Gains depend on input magnitude (Vm) and sampling time (Ts)[cite: 220, 235].
    // Since Vq input scaling is strictly 18-bit, these gains are set to provide 
    // sufficient loop gain to drive the 1 Hz error (59Hz -> 60Hz) to zero.
    // They effectively implement Kp and Ki/Ts.
    localparam signed [31:0] KP = 32'sd2000;  // Proportional Gain
    localparam signed [31:0] KI = 32'sd100;   // Integral Gain (includes Ts factor)
	 
	 // Synthetic Inertia Constant (J)
    // You will likely need to tune this depending on the scaling of pi_output 
    // and the desired damping response.
    localparam signed [31:0] J = 32'sd10;

    // =========================================================================
    // INTERNAL SIGNALS
    // =========================================================================
    
    // Integrator state for the I-term of the PI controller
    // Using 48 bits to prevent overflow during accumulation before truncation
    reg signed [47:0] integrator;
    
    // Signals for PI calculation
    reg signed [47:0] prop_term;
    reg signed [47:0] pi_output;
	 
	 // Register to store the frequency error from the previous 720Hz cycle
    reg signed [47:0] pi_output_prev;
	 
	 // Sign-extend q_in to 48 bits to ensure math behaves predictably
    wire signed [47:0] q_in_ext = $signed(q_in);

    // Calculate the derivative approximation: (Current - Previous) * J
    wire signed [47:0] pi_deriv = (pi_output - pi_output_prev) * J;
    
    // =========================================================================
    // MAIN LOGIC
    // =========================================================================
    
    always @(posedge clk or negedge reset) begin // Reset issue here - negedge but expects positive
        if (reset) begin
            integrator <= 48'd0;
            freq_out   <= CENTER_FREQ;
            prop_term  <= 48'd0;
            pi_output  <= 48'd0;
        end else begin
            // The PLL operates at the sampling rate of the dq transformation (720 Hz)
            if (clk_en) begin
                
                // 1. Proportional Term Calculation
                // P = Kp * error (vq_in)
                prop_term <= -q_in * KP;

                // 2. Integral Term Calculation (Euler Forward)
                // Eq (14): f(k+1) = f(k) + Ts*e(k) 
                // Here, KI incorporates the Ts factor.
                integrator <= integrator + (-q_in * KI);
                
                // 3. PI Output Summation
                // The PI output represents the frequency deviation required to lock.
                pi_output <= prop_term + integrator;

                // 4. Final Output Calculation
                // freq_out = Center_Freq + PI_Output 
                // We take the top 32 bits or clamp/truncate as appropriate. 
                // Here we perform a simple addition, relying on the 32-bit wrap 
                // characteristics of NCOs, though strictly for frequency control 
                // we limit to the valid range.
                freq_out <= CENTER_FREQ + $signed(pi_output[31:0]);
                
            end
        end
    end

endmodule


