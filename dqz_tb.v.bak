*/

dqz dqz_inst (
  .clk(clk),
  .reset(reset),
  .a_in(sig_a),
  .b_in(sig_b),
  .c_in(sig_c),
  .theta(theta),
  //.sine(sig_s),
  //.cosine(sig_cos),
  .d_out(d_out),
  .q_out(q_out)
);

endmodule